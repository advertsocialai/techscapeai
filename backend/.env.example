# ────────────────────────────────────────────────
# TechScape AI — Backend Environment Variables
# Copy this file to .env and fill in the values.
# ────────────────────────────────────────────────

# Application
APP_NAME=TechScape AI API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# CORS — Frontend URL
FRONTEND_URL=https://techscapeai.com
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["https://techscapeai.com","https://www.techscapeai.com"]

# ── Supabase (do NOT change existing values) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Email (optional — for contact form notifications) ──
SENDGRID_API_KEY=
NOTIFICATION_EMAIL=hello@techscapeai.com
FROM_EMAIL=noreply@techscapeai.com
